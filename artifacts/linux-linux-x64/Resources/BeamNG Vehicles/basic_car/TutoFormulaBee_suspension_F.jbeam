"TutoFormulaBee_coilover_F_race": {
    "information":{
        "authors":"BeamNG",
        "name":"Race Front Coilovers",
        "value":750,
    },
    "slotType":"TutoFormulaBee_spring_F",
    "flexbodies":[
        ["mesh", "[group]:", "nonFlexMaterials"],
        ["autobello_coilover_F", ["shocktop_F","lowerarm_F"]],
    ],
    "variables": [
        ["name", "type", "unit", "category", "default", "min", "max", "title", "description"],
        ["$springheight_F", "range", "+m", "Suspension", 0.0, -0.06, 0.04, "Spring Height", "Raise or lower the suspension height", {"stepDis":0.005, "subCategory":"Front"}],
        ["$spring_F", "range", "N/m", "Suspension", 30000, 10000, 100000, "Spring Rate", "Spring stiffness", {"stepDis":500, "subCategory":"Front"}]
        ["$damp_bump_F", "range", "N/m/s", "Suspension", 2000, 500, 4000, "Bump Damping", "Damper rate in compression", {"stepDis":100, "subCategory":"Front"}],
        ["$damp_rebound_F", "range", "N/m/s", "Suspension", 5000, 1000, 8000, "Rebound Damping", "Damper rate in extension", {"stepDis":100, "subCategory":"Front"}],
    ],
    "beams": [
		["id1:", "id2:"],
		//front springs - no soft bumpstop - advanced dampers
		{"beamType":"|NORMAL"},
		{"beamDeform":12000,"beamStrength":140000},
		{"beamSpring":"$spring_F","beamDamp":0},
		["fh1r","fs1r", {"precompressionRange":"$=$springheight_F + 0.015"}],
		["fh1l","fs1l", {"precompressionRange":"$=$springheight_F + 0.015"}],

		//front dampers
		{"beamPrecompression":1.0, "beamType":"|BOUNDED", "beamLongBound":1.0 "beamShortBound":1.0},
		{"beamLimitSpring":0,"beamLimitDamp":0},
		{"beamSpring":250,"beamDamp":"$damp_bump_F"},
		["fh1r","fs1r", {"beamDampRebound":"$damp_rebound_F","beamDampVelocitySplit":0.3,"beamDampFast":"$=$damp_bump_F / 3","beamDampReboundFast":"$=$damp_rebound_F / 3","dampCutoffHz":500,
		  "soundFile":"event:>Vehicle>Suspension>car_vint_sml_01>spring_compress_01","colorFactor":0.8,"attackFactor":10,"volumeFactor":1.8,"decayMode":1,"decayFactor":10,"pitchFactor":0.7,"maxStress":13}],
		["fh1l","fs1l", {"beamDampRebound":"$damp_rebound_F","beamDampVelocitySplit":0.3,"beamDampFast":"$=$damp_bump_F / 3","beamDampReboundFast":"$=$damp_rebound_F / 3","dampCutoffHz":500,
		  "soundFile":"event:>Vehicle>Suspension>car_vint_sml_01>spring_compress_01","colorFactor":0.8,"attackFactor":10,"volumeFactor":1.8,"decayMode":1,"decayFactor":10,"pitchFactor":0.7,"maxStress":13}],

		//bumpstop and extension limiter
		{"beamPrecompression":1, "beamType":"|BOUNDED"},
		{"beamSpring":0,"beamDamp":0},
		{"beamLimitSpring":201000,"beamLimitDamp":5000},
		["fh1r","fs1r", {"longBoundRange":0.04,"shortBoundRange":0.1,"boundZone":0.04,"beamLimitDampRebound":0,"dampCutoffHz":500}],
		["fh1l","fs1l", {"longBoundRange":0.04,"shortBoundRange":0.1,"boundZone":0.04,"beamLimitDampRebound":0,"dampCutoffHz":500}],
		{"beamPrecompression":1.0, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
    ],
},
