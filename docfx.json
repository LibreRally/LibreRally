{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "LibreRally/LibreRally.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "src": "docs",
        "files": [
          "**/*.md",
          "**/toc.yml"
        ]
      },
      {
        "files": [
          "api/**.yml"
        ]
      }
    ],
    "resource": [
      {
        "src": "docs",
        "files": [
          "**/*.png",
          "**/*.jpg",
          "**/*.jpeg",
          "**/*.gif",
          "**/*.svg"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "LibreRally Docs",
      "_appName": "LibreRally Docs",
      "_enableSearch": true
    }
  }
}
